{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "worker-status.v1.schema.json",
  "type": "object",
  "required": [
    "version",
    "status"
  ],
  "properties": {
    "version": {
      "const": "worker-status.v1"
    },
    "status": {
      "type": "string",
      "enum": [
        "DONE",
        "BLOCKED",
        "NEEDS_INFO",
        "FAILED"
      ]
    },
    "question": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
