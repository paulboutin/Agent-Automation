{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "worker-pr-wake.v1.schema.json",
  "type": "object",
  "required": [
    "version",
    "action",
    "head_ref",
    "base_ref"
  ],
  "properties": {
    "version": {
      "const": "worker-pr-wake.v1"
    },
    "repository": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "pr_number": {
      "type": "integer"
    },
    "issue_number": {
      "type": "integer"
    },
    "pr_url": {
      "type": "string"
    },
    "head_ref": {
      "type": "string"
    },
    "base_ref": {
      "type": "string"
    },
    "draft": {
      "type": "boolean"
    },
    "mergeable": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "mergeable_state": {
      "type": "string"
    },
    "merge_conflict": {
      "type": "boolean"
    },
    "conflict_classification": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "sender": {
      "type": "string"
    },
    "requested_reviewer": {
      "type": "string"
    }
  }
}
