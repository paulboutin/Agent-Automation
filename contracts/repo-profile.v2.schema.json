{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-profile.v2.schema.json",
  "type": "object",
  "required": [
    "version",
    "repo",
    "platform",
    "branches",
    "labels",
    "roles",
    "lanes",
    "execution",
    "hosts",
    "packs",
    "protocols"
  ],
  "properties": {
    "version": {
      "const": "repo-profile.v2"
    },
    "repo": {
      "type": "object",
      "required": [
        "id",
        "name"
      ]
    },
    "platform": {
      "type": "object",
      "required": [
        "name"
      ]
    },
    "branches": {
      "type": "object"
    },
    "labels": {
      "type": "object"
    },
    "roles": {
      "type": "array"
    },
    "lanes": {
      "type": "array"
    },
    "execution": {
      "type": "object"
    },
    "hosts": {
      "type": "object"
    },
    "packs": {
      "type": "object"
    },
    "protocols": {
      "type": "object"
    }
  }
}
