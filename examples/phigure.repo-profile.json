{
  "version": "repo-profile.v1",
  "repo": {
    "id": "phigure-app",
    "name": "Phigure App"
  },
  "branches": {
    "development": "development",
    "promotion": [
      "stage",
      "main"
    ],
    "workerBranchFormat": "codex/issue-{issue_number}-{lane}"
  },
  "labels": {
    "ready": "ready",
    "active": "active",
    "needsDecision": "needs-decision",
    "decisionProposed": "decision-proposed",
    "agentFailed": "agent-failed",
    "lanePrefix": "agent:"
  },
  "roles": [
    {
      "name": "implementer",
      "defaultCost": "standard"
    },
    {
      "name": "reviewer",
      "defaultCost": "low"
    },
    {
      "name": "planner",
      "defaultCost": "low"
    },
    {
      "name": "doc-writer",
      "defaultCost": "low"
    },
    {
      "name": "qa-verifier",
      "defaultCost": "standard"
    },
    {
      "name": "coordinator",
      "defaultCost": "standard"
    },
    {
      "name": "operator",
      "defaultCost": "high"
    }
  ],
  "lanes": [
    {
      "name": "backend",
      "defaultCost": "standard"
    },
    {
      "name": "infra",
      "defaultCost": "high"
    },
    {
      "name": "docs",
      "defaultCost": "low"
    },
    {
      "name": "swift",
      "defaultCost": "standard"
    },
    {
      "name": "swiftui",
      "defaultCost": "standard"
    },
    {
      "name": "qa",
      "defaultCost": "low"
    },
    {
      "name": "kotlin",
      "defaultCost": "standard"
    }
  ],
  "costProfiles": {
    "low": {
      "reasoningEffort": "low",
      "hostedModelVar": "CODEX_MODEL_LOW",
      "localModelVar": "WORKER_MODEL_LOW"
    },
    "standard": {
      "reasoningEffort": "medium",
      "hostedModelVar": "CODEX_MODEL_STANDARD",
      "localModelVar": "WORKER_MODEL_STANDARD"
    },
    "high": {
      "reasoningEffort": "high",
      "hostedModelVar": "CODEX_MODEL_HIGH",
      "localModelVar": "WORKER_MODEL_HIGH"
    }
  },
  "protocols": {
    "workerStatus": "worker-status.v1",
    "workerPrWake": "worker-pr-wake.v1"
  },
  "requiredDocs": [
    "AGENTS.md",
    "docs/sprints/COORDINATOR_AGENT_AUTOMATION.md",
    "docs/runbooks/DEV_COORDINATOR_RELAY_RUNBOOK.md"
  ],
  "workflows": {
    "hostedWorker": ".github/workflows/codex-task-worker.yml",
    "unblocker": ".github/workflows/codex-unblocker.yml",
    "prWake": ".github/workflows/codex-coordinator-pr-wake.yml"
  },
  "localAutomation": {
    "workerStart": "scripts/local-worker-start.sh",
    "workerFinish": "scripts/local-worker-finish.sh",
    "workerLaunchTmux": "scripts/local-worker-launch-tmux.sh",
    "workerRunAndRoute": "scripts/local-worker-run-and-route.sh"
  },
  "mergeDaemon": {
    "handler": "scripts/coordinator-relay-handle.sh",
    "poller": "scripts/coordinator-relay-poll.sh",
    "launcher": "scripts/merge-daemon-launch-next.sh",
    "status": "scripts/merge-daemon-status.sh"
  },
  "templates": {
    "issueTask": {
      "description": "Coordinator intake for one automation worker task.",
      "introLines": [
        "Use this template to create one task issue for one automated worker.",
        "The worker attempts to auto-apply the selected `agent:<lane>` from this form.",
        "If auto-apply fails, add exactly one `agent:<lane>` label manually."
      ],
      "automationScopePlaceholder": "feature-voice-runtime",
      "outcomePlaceholder": "Implement X, add tests Y, update docs Z.",
      "scopePlaceholder": "In-scope files..., out-of-scope files...",
      "validationPlaceholderLines": [
        "./scripts/validate-ai-contract-stack.sh",
        "node --test lambda/appsync-resolver/src/ai/*.test.js"
      ],
      "validationDependenciesPlaceholderLines": [
        "authoritative-runtime",
        "#417",
        "ai-contract-stack"
      ],
      "blockersPlaceholder": "Any dependency, secret, role, or product decision still pending."
    },
    "pullRequest": {
      "summaryPromptLines": [
        "What changed?",
        "Why?"
      ],
      "workstreamOptions": [
        "Intent Gateway",
        "Context Firewall",
        "MCP Tool Gateway",
        "Sharing Service",
        "STCL",
        "AI Request API / Orchestrator",
        "Infra / CI / Docs"
      ],
      "workstreamBranchMap": {
        "codex/s1-intent-gateway": "Intent Gateway",
        "codex/s1-context-firewall": "Context Firewall",
        "codex/s1-mcp-tool-gateway": "MCP Tool Gateway",
        "codex/s1-sharing-service": "Sharing Service",
        "codex/s1-stcl": "STCL",
        "codex/s1-ai-request-api": "AI Request API / Orchestrator",
        "codex/s1-automation-ci": "Infra / CI / Docs"
      },
      "checklistItems": [
        "Checklist created and used during implementation",
        "Contracts updated (if interface changed)",
        "Specs/docs updated (if behavior changed)",
        "Validation/tests run and results reviewed",
        "Security/privacy checks reviewed (no raw sensitive logging)"
      ],
      "promotionGateItems": [
        "Human-tested on development (required for `development -> stage`)",
        "Runtime edge smoke gates passed on development (required for `development -> stage`)",
        "Stage deploy readiness checks passed on development (required for `development -> stage`)",
        "Human-tested on stage (required for `stage -> main`)",
        "Runtime edge smoke gates passed on stage (required for `stage -> main`)",
        "Rollback plan validated for stage -> main (required for `stage -> main`)",
        "Production operator checkpoint approved for stage -> main (required for `stage -> main`)"
      ]
    }
  },
  "promotion": {
    "integrationBranches": [
      "development",
      "stage",
      "main"
    ],
    "transitions": [
      {
        "target": "stage",
        "head": "development",
        "base": "stage",
        "sourceEnv": "dev",
        "title": "Promote development -> stage",
        "summary": "Automated promotion PR from `development` to `stage`.",
        "defaultWorkstream": "Infra / CI / Docs",
        "checklistItems": [
          "Release notes reviewed",
          "CI checks green",
          "Human-tested on development"
        ],
        "requiredPromotionGates": [
          "Human-tested on development (required for `development -> stage`)",
          "Runtime edge smoke gates passed on development (required for `development -> stage`)",
          "Stage deploy readiness checks passed on development (required for `development -> stage`)"
        ]
      },
      {
        "target": "main",
        "head": "stage",
        "base": "main",
        "sourceEnv": "stage",
        "title": "Promote stage -> main",
        "summary": "Automated promotion PR from `stage` to `main`.",
        "defaultWorkstream": "Infra / CI / Docs",
        "checklistItems": [
          "Release notes reviewed",
          "CI checks green",
          "Human-tested on stage"
        ],
        "requiredPromotionGates": [
          "Human-tested on stage (required for `stage -> main`)",
          "Runtime edge smoke gates passed on stage (required for `stage -> main`)",
          "Rollback plan validated for stage -> main (required for `stage -> main`)",
          "Production operator checkpoint approved for stage -> main (required for `stage -> main`)"
        ]
      }
    ]
  },
  "concurrency": {
    "baseBranchField": "Base branch",
    "scopeField": "Automation scope",
    "envHelperScript": "tools/agent-factory/scripts/automation-scope-env.sh"
  },
  "operatorProof": {
    "lane": "qa",
    "launchScript": "scripts/local-qa-proof-launch-tmux.sh",
    "runScript": "scripts/local-qa-proof-run.sh --issue <number>"
  }
}
