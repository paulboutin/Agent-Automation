+                  `3. \`git merge origin/${pr.base.ref}\``,
+                  '4. Resolve conflicts, run validation, commit, and push the branch.',
+                ]
+              : [
+                  prMarker,
+                  `Merge conflict cleared for PR #${pr.number}.`,
+                  '',
+                  `- Classification: \`${classification}\``,
+                  `- Mergeable: \`${mergeable}\``,
+                  `- Mergeable state: \`${mergeableState}\``,
+                  `- Checked at: ${new Date().toISOString()}`,
+                ];
+
+            if (hasConflict) {
+              await github.rest.issues.addLabels({
+                owner,
+                repo,
+                issue_number: pr.number,
+                labels: [conflictLabel],
+              }).catch(() => {});
+            } else {
+              await github.rest.issues.removeLabel({
+                owner,
+                repo,
+                issue_number: pr.number,
+                name: conflictLabel,
+              }).catch(() => {});
+            }
+
+            const prComments = await github.paginate(github.rest.issues.listComments, {
+              owner,
+              repo,
+              issue_number: pr.number,
+              per_page: 100,
+            });
+            const existingPrComment = prComments.find((comment) => (comment.body || '').includes(prMarker));
+            if (hasConflict || existingPrComment) {
+              const body = resolutionLines.join('\n');
+              if (existingPrComment) {
+                await github.rest.issues.updateComment({
